# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=exchange
POSTGRES_PASSWORD=exchange
POSTGRES_DB=exchange
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://exchange:exchange@postgres:5432/exchange

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=50

# ─── App ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_SECRET=change-me-in-production-use-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
HMAC_REPLAY_WINDOW_SECONDS=30

# ─── Rate Limiting ──────────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT_PER_MIN=120

# ─── Matching Engine ────────────────────────────────────────────────────────
MATCHING_WORKER_CONCURRENCY=4
MATCHING_QUEUE_BLOCK_TIMEOUT=5

# ─── Frontend (Vite build-time vars) ────────────────────────────────────────
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000

# ─── Admin ──────────────────────────────────────────────────────────────────
VITE_ADMIN_API_BASE=http://localhost:8000

# ─── Docker Compose only ────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=crypto-exchange
